APP_NAME=Company Backend Service
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

# From the host: match the left side of docker-compose ports (e.g. 5433:5432 → use 5433)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

JWT_SECRET_KEY=please-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: seed admin (run: python scripts/seed_admin.py)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
# SEED_ADMIN_FULL_NAME=System Administrator

# PDF uploads (relative to process cwd or absolute path)
# PDF_UPLOAD_DIR=uploads/pdfs
# MAX_PDF_UPLOAD_BYTES=20971520
# CHUNK_SIZE_CHARS=512
# CHUNK_OVERLAP_CHARS=64

# OpenAI embeddings (semantic search + ingestion)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_BATCH_SIZE=16
# OPENAI_EMBEDDING_MAX_RETRIES=6
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_TEMPERATURE=0.3
# OPENAI_CHAT_MAX_TOKENS=1024
