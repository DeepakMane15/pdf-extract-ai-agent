APP_NAME=Company Backend Service
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Use localhost when Postgres publishes -p 5432:5432 (from your Mac, not the container IP)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

JWT_SECRET_KEY=please-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: seed admin (run: python scripts/seed_admin.py)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
# SEED_ADMIN_FULL_NAME=System Administrator

# PDF uploads (relative to process cwd or absolute path)
# PDF_UPLOAD_DIR=uploads/pdfs
# MAX_PDF_UPLOAD_BYTES=20971520
